{
  "name": "dev-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "node --no-deprecation --env-file=.env.local --import tsx/esm src/seed.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-vercel-blob": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@ryancalacsan/caliper-ui": "^0.10.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "lenis": "^1.3.17",
    "lucide-react": "^0.575.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "payload": "3.85.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.9",
    "sass": "^1.97.3",
    "typescript": "5.7.3"
  },
  "overrides": {
    "payload": {
      "undici": "7.28.0"
    }
  }
}
